NODE_ENV=development
PORT=4000

# Postgres — no EasyPanel use a connection string interna do serviço Postgres
DATABASE_URL=postgres://vertex:vertex@localhost:5432/vertex

# JWT — gere valores fortes (openssl rand -hex 32)
JWT_SECRET=troque-por-um-segredo-forte
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte
JWT_ACCESS_TTL=900        # 15min
JWT_REFRESH_TTL=2592000   # 30 dias

# CORS — origem pública do frontend. Em produção, use o domínio HTTPS do frontend.
# Para múltiplos domínios, separe por vírgula.
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Google OAuth — opcional. Deixe vazio para subir apenas com e-mail/senha.
# Quando for usar Google, crie as credenciais no Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
