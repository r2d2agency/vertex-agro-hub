// Prisma schema — Vertex Agro
// Modelo multiempresa com colunas offline-first
// (version, sync_status, device_id, is_deleted, deleted_at)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  admin_global
  admin_empresa
  gestor
  supervisor_regional
  monitor
  consultor
  consulta
}

enum SyncStatus {
  synced
  pending
  conflict
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")
  fullName     String?  @map("full_name")
  avatarUrl    String?  @map("avatar_url")
  googleId     String?  @unique @map("google_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles         UserRole[]
  refreshTokens RefreshToken[]
  companies     Company[]  @relation("CompanyCreatedBy")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, role])
  @@index([userId])
  @@index([companyId])
  @@map("user_roles")
}

model Company {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  legalName    String?    @map("legal_name")
  taxId        String?    @map("tax_id")
  email        String?
  phone        String?
  logoUrl      String?    @map("logo_url")
  active       Boolean    @default(true)

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  createdBy User?      @relation("CompanyCreatedBy", fields: [createdById], references: [id])
  members   UserRole[]
  regionals Regional[]
  farms     Farm[]
  plots     Plot[]

  @@index([isDeleted])
  @@map("companies")
}

model Regional {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @map("company_id") @db.Uuid
  name        String
  code        String?
  description String?
  manager     String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  farms   Farm[]

  @@index([companyId, isDeleted])
  @@map("regionals")
}

model Farm {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  regionalId   String?  @map("regional_id") @db.Uuid
  name         String
  code         String?
  city         String?
  state        String?
  totalAreaHa  Float?   @map("total_area_ha")
  latitude     Float?
  longitude    Float?
  owner        String?
  notes        String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  regional Regional? @relation(fields: [regionalId], references: [id], onDelete: SetNull)
  plots    Plot[]

  @@index([companyId, isDeleted])
  @@index([regionalId])
  @@map("farms")
}

model Plot {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  farmId        String   @map("farm_id") @db.Uuid
  name          String
  code          String?
  areaHa        Float?   @map("area_ha")
  cloneName     String?  @map("clone_name")
  plantingYear  Int?     @map("planting_year")
  treeCount     Int?     @map("tree_count")
  tappingSystem String?  @map("tapping_system")
  notes         String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  farm    Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([farmId])
  @@map("plots")
}
