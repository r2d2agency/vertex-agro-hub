// Prisma schema — Vertex Agro
// Modelo multiempresa com colunas offline-first
// (version, sync_status, device_id, is_deleted, deleted_at)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  admin_global
  admin_empresa
  gestor
  supervisor_regional
  monitor
  consultor
  consulta
}

enum SyncStatus {
  synced
  pending
  conflict
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")
  fullName     String?  @map("full_name")
  avatarUrl    String?  @map("avatar_url")
  googleId     String?  @unique @map("google_id")

  // Ficha pessoal
  cpf                   String?  @unique
  rg                    String?
  birthDate             DateTime? @map("birth_date") @db.Date
  gender                String?
  maritalStatus         String?  @map("marital_status")
  nationality           String?
  phone                 String?
  phoneAlt              String?  @map("phone_alt")
  addressCep            String?  @map("address_cep")
  addressStreet         String?  @map("address_street")
  addressNumber         String?  @map("address_number")
  addressComplement     String?  @map("address_complement")
  addressDistrict       String?  @map("address_district")
  addressCity           String?  @map("address_city")
  addressState          String?  @map("address_state")
  emergencyContactName  String?  @map("emergency_contact_name")
  emergencyContactPhone String?  @map("emergency_contact_phone")
  notes                 String?

  // Acesso ao sistema
  active                Boolean  @default(true)
  deactivatedAt         DateTime? @map("deactivated_at")
  deactivationReason    String?  @map("deactivation_reason")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles         UserRole[]
  refreshTokens RefreshToken[]
  companies     Company[]  @relation("CompanyCreatedBy")
  teamMemberships TeamMember[]
  managedRegionals Regional[] @relation("RegionalManager")
  employments   PersonEmployment[]
  documents     PersonDocument[]
  assignments   FarmAssignment[]  @relation("AssignmentUser")
  consultingAssignments FarmAssignment[] @relation("AssignmentConsultor")
  evaluations   PersonEvaluation[] @relation("EvaluationUser")
  evaluationsGiven PersonEvaluation[] @relation("EvaluationEvaluator")

  @@map("users")
}

model PersonEmployment {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  position        String?
  employeeCode    String?  @map("employee_code")
  admissionDate   DateTime? @map("admission_date") @db.Date
  terminationDate DateTime? @map("termination_date") @db.Date
  contractType    String?  @map("contract_type")
  salary          Decimal? @db.Decimal(12, 2)
  pisNumber       String?  @map("pis_number")
  ctpsNumber      String?  @map("ctps_number")
  bankName        String?  @map("bank_name")
  bankAgency      String?  @map("bank_agency")
  bankAccount     String?  @map("bank_account")
  bankPixKey      String?  @map("bank_pix_key")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("person_employments")
}

model PersonDocument {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  companyId  String?  @map("company_id") @db.Uuid
  kind       String
  name       String
  number     String?
  fileUrl    String?  @map("file_url")
  issuedAt   DateTime? @map("issued_at") @db.Date
  expiresAt  DateTime? @map("expires_at") @db.Date
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@map("person_documents")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, role])
  @@index([userId])
  @@index([companyId])
  @@map("user_roles")
}

model Company {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  legalName    String?    @map("legal_name")
  taxId        String?    @map("tax_id")
  email        String?
  phone        String?
  logoUrl      String?    @map("logo_url")
  active       Boolean    @default(true)

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  createdBy User?      @relation("CompanyCreatedBy", fields: [createdById], references: [id])
  members   UserRole[]
  regionals Regional[]
  farms     Farm[]
  plots     Plot[]
  clones    Clone[]
  tappingTables TappingTable[]
  tappingRecords TappingRecord[]
  productionDeliveries ProductionDelivery[]
  teams     Team[]
  occurrences Occurrence[]
  scheduledTasks ScheduledTask[]
  employments   PersonEmployment[]
  personDocuments PersonDocument[]
  stimulations Stimulation[]
  photos      Photo[]
  auditLogs   AuditLog[]
  systemLogs  SystemLog[]
  syncSessions SyncSession[]
  alertRules  AlertRule[]
  alertEvents AlertEvent[]
  integrations Integration[]
  settings    CompanySettings?


  @@index([isDeleted])
  @@map("companies")
}


model Regional {
  id            String     @id @default(uuid()) @db.Uuid
  companyId     String     @map("company_id") @db.Uuid
  name          String
  code          String?
  description   String?
  manager       String?
  managerUserId String?    @map("manager_user_id") @db.Uuid

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  managerUser User?   @relation("RegionalManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  farms       Farm[]

  @@index([companyId, isDeleted])
  @@index([managerUserId])
  @@map("regionals")
}

model Farm {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  regionalId   String?  @map("regional_id") @db.Uuid
  name         String
  code         String?
  city         String?
  state        String?
  totalAreaHa  Float?   @map("total_area_ha")
  latitude     Float?
  longitude    Float?
  owner        String?
  notes        String?
  boundary     Json?
  centroidLat  Float?   @map("centroid_lat")
  centroidLng  Float?   @map("centroid_lng")
  bboxJson     Json?    @map("bbox")


  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  regional Regional? @relation(fields: [regionalId], references: [id], onDelete: SetNull)
  plots    Plot[]
  assignments FarmAssignment[]

  @@index([companyId, isDeleted])
  @@index([regionalId])
  @@map("farms")
}

model FarmAssignment {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  farmId           String   @map("farm_id") @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  role             String
  consultorUserId  String?  @map("consultor_user_id") @db.Uuid
  startAt          DateTime @map("start_at") @db.Date
  endAt            DateTime? @map("end_at") @db.Date
  endReason        String?  @map("end_reason")
  notes            String?
  createdById      String?  @map("created_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user      User @relation("AssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  farm      Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  consultor User? @relation("AssignmentConsultor", fields: [consultorUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([farmId])
  @@index([companyId, role])
  @@index([farmId, endAt])
  @@map("farm_assignments")
}

model PersonEvaluation {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  evaluatorUserId String?  @map("evaluator_user_id") @db.Uuid
  ratedAt         DateTime @map("rated_at") @db.Date
  rating          Int
  category        String?
  title           String?
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user      User  @relation("EvaluationUser", fields: [userId], references: [id], onDelete: Cascade)
  evaluator User? @relation("EvaluationEvaluator", fields: [evaluatorUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@map("person_evaluations")
}

model Plot {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  farmId        String   @map("farm_id") @db.Uuid
  name          String
  code          String?
  areaHa        Float?   @map("area_ha")
  cloneName     String?  @map("clone_name")
  plantingYear  Int?     @map("planting_year")
  treeCount     Int?     @map("tree_count")
  tappingSystem String?  @map("tapping_system")
  notes         String?
  boundary      Json?
  centroidLat   Float?   @map("centroid_lat")
  centroidLng   Float?   @map("centroid_lng")
  bboxJson      Json?    @map("bbox")


  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  farm    Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([farmId])
  @@map("plots")
}

model Clone {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  name           String
  code           String?
  origin         String?
  productivity   String?
  vigor          String?
  diseaseResistance String? @map("disease_resistance")
  recommendedRegion String? @map("recommended_region")
  notes          String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@map("clones")
}

model TappingTable {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  name           String
  code           String?
  notation       String?
  cutType        String?  @map("cut_type")
  frequencyDays  Int?     @map("frequency_days")
  restDays       Int?     @map("rest_days")
  workDaysCycle  Int?     @map("work_days_cycle")
  stimulation    String?
  description    String?
  active         Boolean  @default(true)

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@map("tapping_tables")
}

model TappingRecord {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  farmId         String?  @map("farm_id") @db.Uuid
  plotId         String?  @map("plot_id") @db.Uuid
  tappingTableId String?  @map("tapping_table_id") @db.Uuid
  date           DateTime @db.Date
  sangradorName  String   @map("sangrador_name")
  treesTapped    Int?     @map("trees_tapped")
  liters         Float?
  drcPercent     Float?   @map("drc_percent")
  dryKg          Float?   @map("dry_kg")
  adherencePct   Float?   @map("adherence_pct")
  notes          String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([companyId, date])
  @@index([farmId])
  @@index([plotId])
  @@map("tapping_records")
}

model ProductionDelivery {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  farmId         String?  @map("farm_id") @db.Uuid
  season         String?
  deliveryDate   DateTime @map("delivery_date") @db.Date
  turnDay        Int?     @map("turn_day")
  propertyName   String?  @map("property_name")
  ownerName      String?  @map("owner_name")
  status         String?
  consultantName String?  @map("consultant_name")
  monitorName    String?  @map("monitor_name")
  coagulant      String?
  latexType      String?  @map("latex_type")
  grossWeightKg  Float?   @map("gross_weight_kg")
  netWeightKg    Float?   @map("net_weight_kg")
  drcAvgPercent  Float?   @map("drc_avg_percent")
  dryKg          Float?   @map("dry_kg")
  notes          String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([companyId, deliveryDate])
  @@index([farmId])
  @@map("production_deliveries")
}


model Team {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String?
  active      Boolean  @default(true)

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@index([companyId, isDeleted])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleLabel String?  @map("role_label")
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model Occurrence {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  farmId      String?  @map("farm_id") @db.Uuid
  plotId      String?  @map("plot_id") @db.Uuid
  date        DateTime @db.Date
  type        String
  severity    String   @default("baixa")
  status      String   @default("aberta")
  title       String
  description String?
  responsible String?
  resolvedAt  DateTime? @map("resolved_at")

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([companyId, date])
  @@index([farmId])
  @@map("occurrences")
}

model ScheduledTask {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  farmId      String?  @map("farm_id") @db.Uuid
  plotId      String?  @map("plot_id") @db.Uuid
  teamId      String?  @map("team_id") @db.Uuid
  title       String
  description String?
  category    String   @default("sangria")
  priority    String   @default("media")
  status      String   @default("planejada")
  scheduledAt DateTime @map("scheduled_at")
  dueAt       DateTime? @map("due_at")
  completedAt DateTime? @map("completed_at")
  responsible String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([companyId, scheduledAt])
  @@index([farmId])
  @@index([teamId])
  @@map("scheduled_tasks")
}

model Stimulation {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  farmId          String?  @map("farm_id") @db.Uuid
  plotId          String?  @map("plot_id") @db.Uuid
  date            DateTime @db.Date
  product         String
  concentration   String?
  method          String?
  applicator      String?
  treesStimulated Int?     @map("trees_stimulated")
  doseMlPerTree   Float?   @map("dose_ml_per_tree")
  areaHa          Float?   @map("area_ha")
  weather         String?
  notes           String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([companyId, date])
  @@index([farmId])
  @@map("stimulations")
}

model Photo {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  farmId     String?  @map("farm_id") @db.Uuid
  plotId     String?  @map("plot_id") @db.Uuid
  takenAt    DateTime @map("taken_at")
  url        String
  thumbUrl   String?  @map("thumb_url")
  latitude   Float?
  longitude  Float?
  accuracyM  Float?   @map("accuracy_m")
  category   String?
  caption    String?
  author     String?

  version      Int        @default(1)
  syncStatus   SyncStatus @default(synced) @map("sync_status")
  deviceId     String?    @map("device_id")
  isDeleted    Boolean    @default(false) @map("is_deleted")
  deletedAt    DateTime?  @map("deleted_at")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isDeleted])
  @@index([companyId, takenAt])
  @@index([farmId])
  @@map("photos")
}

